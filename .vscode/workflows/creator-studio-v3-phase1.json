      "data": {
        "label": "1.1 🔴 叙事框架选择",
        "questionText": "选择口播文案的叙事框架：",
        "options": [
          {
            "id": "opt-golden-circle",
            "label": "黄金圈",
            "description": "Why → How → What — 适合理念/品牌视频"
          },
          {
            "id": "opt-scqa",
            "label": "SCQA",
            "description": "情境 → 冲突 → 问题 → 答案 — 适合商业分析/知识科普"
